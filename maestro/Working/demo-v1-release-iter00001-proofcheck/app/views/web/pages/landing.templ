package pages

// Renders: starter landing page.
templ Landing() {
	<section data-component="landing">
		<div data-slot="status">Fresh App Ready</div>
		<h1>Demo V1 Release Iter00001 Proofcheck</h1>
		<p>Landing page scaffold with auth entrypoints, a starter migration, and one obvious path to boot and verify a fresh app.</p>
	</section>
}
