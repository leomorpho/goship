package pages

import "github.com/leomorpho/goship/app/controller"

// Renders: full-screen green page stating service is up and running
// Route(s): rendered by app/router.go page handlers

templ HealthCheck(page *controller.Page) {
	<div data-component="health-check" class="bg-green-500 h-screen flex items-center justify-center">
		<h1 class="text-white text-3xl">Service is up and running!</h1>
	</div>
}

