# Optional CLI-only override for DB commands. Leave blank to derive the URL from PAGODA_DATABASE_* values.
DATABASE_URL=

# Runtime profile: server-db, single-node, or distributed.
PAGODA_RUNTIME_PROFILE=

# Enable the web process.
PAGODA_PROCESSES_WEB=
# Enable the worker process.
PAGODA_PROCESSES_WORKER=
# Enable the scheduler process.
PAGODA_PROCESSES_SCHEDULER=
# Run web, worker, and scheduler in one process.
PAGODA_PROCESSES_COLOCATED=

# Database adapter implementation.
PAGODA_ADAPTERS_DB=sqlite
# Cache adapter implementation.
PAGODA_ADAPTERS_CACHE=otter
PAGODA_CACHE_DRIVER=
# Jobs adapter implementation.
PAGODA_ADAPTERS_JOBS=backlite
PAGODA_JOBS_DRIVER=
# PubSub adapter implementation.
PAGODA_ADAPTERS_PUBSUB=inproc

# Database driver and path for single-binary mode.
PAGODA_DB_DRIVER=sqlite
PAGODA_DB_PATH=.local/db/main.db

# HTTP listen hostname.
PAGODA_HTTP_HOSTNAME=
# HTTP listen port.
PAGODA_HTTP_PORT=
# Public application domain.
PAGODA_HTTP_DOMAIN=
# HTTP read timeout duration.
PAGODA_HTTP_READTIMEOUT=
# HTTP write timeout duration.
PAGODA_HTTP_WRITETIMEOUT=
# HTTP idle timeout duration.
PAGODA_HTTP_IDLETIMEOUT=
# Server-sent events keepalive duration.
PAGODA_HTTP_SSEKEEPALIVE=
# Enable TLS for the HTTP server.
PAGODA_HTTP_TLS_ENABLED=
# TLS certificate file path.
PAGODA_HTTP_TLS_CERTIFICATE=
# TLS private key file path.
PAGODA_HTTP_TLS_KEY=

# Application display name.
PAGODA_APP_NAME=
# Public support email.
PAGODA_APP_SUPPORTEMAIL=
# Application environment: local, test, dev, staging, qa, or prod.
PAGODA_APP_ENVIRONMENT=
# Primary application encryption key.
PAGODA_APP_ENCRYPTIONKEY=
# Request timeout duration.
PAGODA_APP_TIMEOUT=
# Email verification token expiration duration.
PAGODA_APP_EMAILVERIFICATIONTOKENEXPIRATION=
# Default pagination size.
PAGODA_APP_PAGESIZE=
# Web Push VAPID public key.
PAGODA_APP_VAPIDPUBLICKEY=
# Web Push VAPID private key.
PAGODA_APP_VAPIDPRIVATEKEY=
# Sentry DSN.
PAGODA_APP_SENTRYDSN=
# Test Sentry URL used by diagnostics.
PAGODA_APP_TESTSENTRYURL=
# Stripe publishable key.
PAGODA_APP_PUBLICSTRIPEKEY=
# Stripe secret key.
PAGODA_APP_PRIVATESTRIPEKEY=
# Stripe webhook signing secret.
PAGODA_APP_STRIPEWEBHOOKSECRET=
# Stripe webhook route path.
PAGODA_APP_STRIPEWEBHOOKPATH=
# Secondary application encryption key.
PAGODA_APP_APPENCRYPTIONKEY=
# Base64-encoded Firebase service account JSON.
PAGODA_APP_FIREBASEBASE64ACCESSKEYS=
# Password token expiration duration.
PAGODA_APP_PASSWORDTOKEN_EXPIRATION=
# Password token length.
PAGODA_APP_PASSWORDTOKEN_LENGTH=
# Enable newsletter signup.
PAGODA_APP_OPERATIONALCONSTANTS_NEWSLETTERSIGNUPENABLED=
# Enable general user signup.
PAGODA_APP_OPERATIONALCONSTANTS_USERSIGNUPENABLED=
# Enable signup from the landing page.
PAGODA_APP_OPERATIONALCONSTANTS_USERSIGNUPENABLEDONLANDINGPAGE=
# Days a question interaction remains valid.
PAGODA_APP_OPERATIONALCONSTANTS_QUESTIONINTERACTIONVALIDLIFETIMEINDAYS=
# Minimum shared answers required for private messages.
PAGODA_APP_OPERATIONALCONSTANTS_NUMMINSHAREDANSWERSFORPRIVATEMESSAGES=
# Emoji notification debounce duration.
PAGODA_APP_OPERATIONALCONSTANTS_NOTIFEMOJIDEBOUNCETIME=
# Debounce duration for unanswered-question notifications.
PAGODA_APP_OPERATIONALCONSTANTS_NOTIFYNEWANSWERFROMUNANSWEREDQUESTIONDEBOUNCETIME=
# Minimum answer length.
PAGODA_APP_OPERATIONALCONSTANTS_MINANSWERLEN=
# Enable payments.
PAGODA_APP_OPERATIONALCONSTANTS_PAYMENTSENABLED=
# Pro trial length in days.
PAGODA_APP_OPERATIONALCONSTANTS_PROTRIALTIMESPANINDAYS=
# Stripe price code for Pro.
PAGODA_APP_OPERATIONALCONSTANTS_PRODUCTPROCODE=
# Pro price amount.
PAGODA_APP_OPERATIONALCONSTANTS_PRODUCTPROPRICE=
# Grace period after payment failure in days.
PAGODA_APP_OPERATIONALCONSTANTS_PAYMENTFAILEDGRACEPERIODINDAYS=
# Days before stale notifications are deleted.
PAGODA_APP_OPERATIONALCONSTANTS_DELETESTALENOTIFICATIONAFTERDAYS=
# Maximum liked-question history for free users.
PAGODA_APP_OPERATIONALCONSTANTS_MAXLIKEDQUESTIONHISTORYFREEPLAN=

# Cache hostname.
PAGODA_CACHE_HOSTNAME=
# Cache port.
PAGODA_CACHE_PORT=
# Cache password.
PAGODA_CACHE_PASSWORD=
# Cache database number.
PAGODA_CACHE_DATABASE=
# Cache database number for tests.
PAGODA_CACHE_TESTDATABASE=
# Static file cache expiration duration.
PAGODA_CACHE_EXPIRATIONSTATICFILE=
# Page cache expiration duration.
PAGODA_CACHE_EXPIRATIONPAGE=

# Database mode: embedded or standalone.
PAGODA_DATABASE_DBMODE=
# Database driver: sqlite or postgres.
PAGODA_DB_DRIVER=
# SQLite database path when using PAGODA_DB_DRIVER=sqlite.
PAGODA_DB_PATH=
# Embedded database driver name.
PAGODA_DATABASE_EMBEDDEDDRIVER=
# Embedded database connection string.
PAGODA_DATABASE_EMBEDDEDCONNECTION=
# Embedded database connection string used in tests.
PAGODA_DATABASE_EMBEDDEDTESTCONNECTION=
# Standalone database hostname.
PAGODA_DATABASE_HOSTNAME=
# Standalone database port.
PAGODA_DATABASE_PORT=
# Standalone database user.
PAGODA_DATABASE_USER=
# Standalone database password.
PAGODA_DATABASE_PASSWORD=
# Local database name.
PAGODA_DATABASE_DATABASENAMELOCAL=
# Production database name.
PAGODA_DATABASE_DATABASENAMEPROD=
# Test database name.
PAGODA_DATABASE_TESTDATABASE=
# TLS CA certificate path for the database.
PAGODA_DATABASE_SSLCERTPATH=
# Database SSL mode.
PAGODA_DATABASE_SSLMODE=

# Mail service hostname.
PAGODA_MAIL_HOSTNAME=
# Mail service HTTP port.
PAGODA_MAIL_HTTPPORT=
# Mail service SMTP port.
PAGODA_MAIL_SMTPPORT=
# Mail service username.
PAGODA_MAIL_USER=
# Mail service password.
PAGODA_MAIL_PASSWORD=
# Mail driver: log, smtp, or resend.
PAGODA_MAIL_DRIVER=log
# Alias of PAGODA_MAIL_DRIVER.
MAIL_DRIVER=
# Default outgoing mail from-name.
PAGODA_MAIL_FROM_NAME=GoShip App
# Alias of PAGODA_MAIL_FROM_NAME.
MAIL_FROM_NAME=
# Default outgoing mail from-address.
PAGODA_MAIL_FROMADDRESS=
# Alias of PAGODA_MAIL_FROMADDRESS.
MAIL_FROM_ADDRESS=
# SMTP host when using MAIL_DRIVER=smtp.
PAGODA_MAIL_SMTP_HOST=
# Alias of PAGODA_MAIL_SMTP_HOST.
MAIL_SMTP_HOST=
# SMTP port when using MAIL_DRIVER=smtp.
PAGODA_MAIL_SMTP_PORT=587
# Alias of PAGODA_MAIL_SMTP_PORT.
MAIL_SMTP_PORT=
# SMTP username when using MAIL_DRIVER=smtp.
PAGODA_MAIL_SMTP_USER=
# Alias of PAGODA_MAIL_SMTP_USER.
MAIL_SMTP_USER=
# SMTP password when using MAIL_DRIVER=smtp.
PAGODA_MAIL_SMTP_PASS=
# Alias of PAGODA_MAIL_SMTP_PASS.
MAIL_SMTP_PASS=
# Enable SMTP TLS.
PAGODA_MAIL_SMTP_TLS=true
# Alias of PAGODA_MAIL_SMTP_TLS.
MAIL_SMTP_TLS=
# Resend API key.
PAGODA_MAIL_RESENDAPIKEY=
# Preferred Resend API key variable.
PAGODA_MAIL_RESEND_API_KEY=
# Alias of PAGODA_MAIL_RESEND_API_KEY.
MAIL_RESEND_API_KEY=

# SMS sender identifier.
PAGODA_PHONE_SENDERID=
# Default SMS region code.
PAGODA_PHONE_REGION=
# Validation code expiration in minutes.
PAGODA_PHONE_VALIDATIONCODEEXPIRATIONMINUTES=

# GitHub OAuth client ID.
OAUTH_GITHUB_CLIENT_ID=
# GitHub OAuth client secret.
OAUTH_GITHUB_CLIENT_SECRET=
# Google OAuth client ID.
OAUTH_GOOGLE_CLIENT_ID=
# Google OAuth client secret.
OAUTH_GOOGLE_CLIENT_SECRET=
# Discord OAuth client ID.
OAUTH_DISCORD_CLIENT_ID=
# Discord OAuth client secret.
OAUTH_DISCORD_CLIENT_SECRET=

# AI provider driver: anthropic, openai, or openrouter.
AI_DRIVER=
# Anthropic API key.
ANTHROPIC_API_KEY=
# Default Anthropic model.
ANTHROPIC_DEFAULT_MODEL=
# OpenAI API key.
OPENAI_API_KEY=
# Default OpenAI model.
OPENAI_DEFAULT_MODEL=
# OpenRouter API key.
OPENROUTER_API_KEY=
# Default OpenRouter model.
OPENROUTER_DEFAULT_MODEL=
# Optional OpenRouter site URL for attribution headers.
OPENROUTER_SITE_URL=
# Optional OpenRouter site name for attribution headers.
OPENROUTER_SITE_NAME=

# Batch size for recommender matching.
PAGODA_RECOMMENDER_NUMPROFILESTOMATCHATONCE=

# Storage driver: local or minio.
PAGODA_STORAGE_DRIVER=local
# Local storage path for 'local' driver.
PAGODA_STORAGE_LOCALSTORAGEPATH=./uploads
# Primary application storage bucket.
PAGODA_STORAGE_APPBUCKETNAME=
# Bucket for static assets.
PAGODA_STORAGE_STATICFILESBUCKETNAME=
# S3-compatible endpoint hostname.
PAGODA_STORAGE_S3ENDPOINT=
# S3-compatible access key.
PAGODA_STORAGE_S3ACCESSKEY=
# S3-compatible secret key.
PAGODA_STORAGE_S3SECRETKEY=
# Enable SSL for S3-compatible storage.
PAGODA_STORAGE_S3USESSL=
# Maximum profile photo size in MB.
PAGODA_STORAGE_PROFILEPHOTOMAXFILESIZEMB=
# Maximum gallery photo size in MB.
PAGODA_STORAGE_PHOTOSMAXFILESIZEMB=
