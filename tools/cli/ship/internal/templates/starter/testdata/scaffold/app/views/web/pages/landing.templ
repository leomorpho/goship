package pages

// Renders: starter landing page.
templ Landing() {
	<section data-component="starter-landing" class="starter-panel">
		<div class="starter-status">Fresh App Ready</div>
		<h1>GoShip Starter</h1>
		<p>Landing page scaffold with auth entrypoints, a starter migration, and one obvious path to boot and verify a fresh app.</p>
	</section>
}
